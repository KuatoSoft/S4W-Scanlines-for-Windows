</Border>


            <!-- ═══════ TAB BAR ═══════ -->
            <Border Grid.Row="1" Background="#080A10" Padding="16,0,16,0"
                    BorderBrush="#1A1D28" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tab 1 -->
                    <Border Grid.Column="0" Cursor="Hand"
                            MouseLeftButtonDown="TabBtn1_Click" Padding="0,10,0,8"
                            Style="{StaticResource TabBorderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"
                                           x:Name="TabBtn1Icon" Foreground="White"/>
                                <TextBlock x:Name="TabBtn1Text" Text="LAYER CONFIGURATION"
                                           Foreground="White" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="TabBtn1Indicator" Height="2" Background="#FF2AFF"
                                    CornerRadius="1"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab 2 — CRT EFFECTS -->
                    <Border Grid.Column="1" Cursor="Hand"
                            MouseLeftButtonDown="TabBtn2_Click" Padding="0,10,0,8"
                            Style="{StaticResource TabBorderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"
                                           x:Name="TabBtn2Icon" Foreground="#6B7280"/>
                                <TextBlock x:Name="TabBtn2Text" Text="CRT EFFECTS"
                                           Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="TabBtn2Indicator" Height="2" Background="#FF2AFF"
                                    CornerRadius="1" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab 3 — SYSTEM SETTINGS -->
                    <Border Grid.Column="2" Cursor="Hand"
                            MouseLeftButtonDown="TabBtn3_Click" Padding="0,10,0,8"
                            Style="{StaticResource TabBorderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"
                                           x:Name="TabBtn3Icon" Foreground="#6B7280"/>
                                <TextBlock x:Name="TabBtn3Text" Text="SYSTEM SETTINGS"
                                           Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border x:Name="TabBtn3Indicator" Height="2" Background="#FF2AFF"
                                    CornerRadius="1" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════ -->
            <!--     TAB 1 — LAYER CONFIGURATION       -->
            <!-- ══════════════════════════════════════ -->
            <ScrollViewer Grid.Row="2" x:Name="Tab1Content"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="18,14,18,8">

                    <!-- ── BEZEL ── -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="LblBezelSectionHeader" Text="BEZEL"
                                   Foreground="#6B7280" FontSize="13" FontWeight="SemiBold"/>
                        <Border x:Name="InfoBezel" Width="15" Height="15" CornerRadius="8"
                                BorderThickness="1" Background="Transparent"
                                Margin="6,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                                IsEnabled="True"
                                ToolTipService.InitialShowDelay="0"
                                ToolTipService.ShowOnDisabled="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#4B5563"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#FF2AFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="i" FontSize="9" FontWeight="Bold"
                                       FontFamily="Segoe UI" FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6B7280"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                <Setter Property="Foreground" Value="#FF2AFF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <Border Background="#151921" CornerRadius="10"
                            BorderBrush="#1A1D28" BorderThickness="1"
                            Padding="16,16" Margin="0,0,0,16">
                        <StackPanel>
                            <!-- FILE PATH header + enable toggle -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton Grid.Column="0" x:Name="ToggleBezelEnabled"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              IsChecked="False"
                                              Margin="0,0,8,0"
                                              Checked="ToggleBezelEnabled_Changed"
                                              Unchecked="ToggleBezelEnabled_Changed"/>
                                <TextBlock Grid.Column="1" x:Name="LblFilePath" Text="FILE PATH"
                                           Foreground="#6B7280" FontSize="10" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- Bezel controls — grayed out when toggle is off -->
                            <StackPanel x:Name="BezelContentPanel" IsEnabled="False" Opacity="0.35">
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="TxtBezelPath" Text="None"
                                             Style="{StaticResource DarkTextBox}" Margin="0,0,8,0"/>
                                    <!-- Prev bezel -->
                                    <Button Grid.Column="1" x:Name="BtnBezelPrev" Content="◀"
                                            Width="28" Height="34" Padding="0"
                                            Click="BtnBezelPrev_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#1E2230"/>
                                                <Setter Property="Foreground" Value="#6B7280"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="#2A2D38" BorderThickness="1"
                                                                    CornerRadius="6,0,0,6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2A2D38"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <!-- Next bezel -->
                                    <Button Grid.Column="2" x:Name="BtnBezelNext" Content="▶"
                                            Width="28" Height="34" Padding="0" Margin="0,0,8,0"
                                            Click="BtnBezelNext_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#1E2230"/>
                                                <Setter Property="Foreground" Value="#6B7280"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="#2A2D38" BorderThickness="1"
                                                                    CornerRadius="0,6,6,0">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2A2D38"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Grid.Column="3" x:Name="BtnBezelSearchBtn" Content="Set"
                                            Style="{StaticResource DarkButton}" Click="BtnBezelSearch_Click"
                                            Margin="0,0,8,0"/>
                                    <Button Grid.Column="4" x:Name="BtnBezelResetBtn" Content="Reset"
                                            Style="{StaticResource DarkButton}" Click="BtnBezelReset_Click"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblBezelOpacity" Text="OPACITY"
                                               Foreground="#6B7280" FontSize="10" FontWeight="SemiBold"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock Grid.Column="1" x:Name="TxtBezelOpacityPct"
                                               Text="{Binding Value, ElementName=SliderBezelOpacity, StringFormat={}{0:0}%}"
                                               Foreground="#FF2AFF" FontSize="12" FontWeight="SemiBold"/>
                                </Grid>
                                <Slider x:Name="SliderBezelOpacity"
                                        Style="{StaticResource PinkSlider}"
                                        Minimum="0" Maximum="100" Value="0"
                                        Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                        AutoToolTipPlacement="TopLeft"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── SCANLINES GENERATOR ── -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE8EF;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="LblScanlinesSectionHeader" Text="SCANLINES GENERATOR"
                                   Foreground="#6B7280" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Horizontal Card -->
                        <Border Grid.Column="0" x:Name="HorizontalSection" Background="#151921" CornerRadius="10"
                                BorderBrush="#1A1D28" BorderThickness="1" Padding="12,14">

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <ToggleButton x:Name="ToggleHorizontal"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  IsChecked="True"
                                                  Checked="ToggleHorizontal_Changed"
                                                  Unchecked="ToggleHorizontal_Changed"/>
                                    <TextBlock x:Name="LblHorizontal" Text="HORIZONTAL"
                                               Foreground="#6B7280" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                                <Grid Margin="0,0,0,4">
