                                    Click="BtnPresetSave_Click"/>

                            <!-- Delete preset -->
                            <Button Grid.Column="5" x:Name="BtnPresetDelete"
                                    Style="{StaticResource DarkButton}"
                                    Height="34" Padding="10,4" Margin="6,0,0,0"
                                    Click="BtnPresetDelete_Click"/>
                        </Grid>
                    </Grid>

                    <StackPanel x:Name="CrtEffectsBody" Grid.IsSharedSizeScope="True">

                    <!-- CRT EFFECTS GROUP (Curvature / Blur / Bloom / Flicker / Phosphor / Luma) -->
                    <Border Background="#0D1117" CornerRadius="12" Padding="16,18" Margin="0,0,0,16"
                            BorderBrush="#1E2230" BorderThickness="1">
                        <StackPanel>
                            <!-- Master header -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="ToggleCrtGroup" Grid.Column="0"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="True"
                                          Checked="ToggleCrtGroup_Changed" Unchecked="ToggleCrtGroup_Changed"/>
                                <TextBlock Grid.Column="1" x:Name="LblCrtGroupTitle" Text="CRT"
                                           Foreground="White" FontSize="13" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <Border x:Name="InfoCrtGroup" Grid.Column="2" Width="15" Height="15" CornerRadius="8"
                                        BorderThickness="1" Background="Transparent"
                                        Margin="6,0,4,0" VerticalAlignment="Center" Cursor="Hand"
                                        IsEnabled="True"
                                        ToolTipService.InitialShowDelay="0"
                                        ToolTipService.ShowOnDisabled="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#4B5563"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FF2AFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="i" FontSize="9" FontWeight="Bold"
                                               FontFamily="Segoe UI" FontStyle="Italic"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#6B7280"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF2AFF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <Button x:Name="BtnCollapseCrtGroup" Grid.Column="4"
                                        Style="{StaticResource CrtCollapseBtn}"
                                        Click="BtnCollapseCrtGroup_Click"
                                        VerticalAlignment="Center" Content="▲"/>
                            </Grid>

                            <StackPanel x:Name="CrtGroupBody" Visibility="Visible">
                                <StackPanel x:Name="CrtGroupContentPanel">

                                <!-- ── CURVATURE ── -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleCurvature" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="False"
                                              Checked="ToggleCurvature_Changed" Unchecked="ToggleCurvature_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblCurvatureTitle" Text="CURVATURE"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock x:Name="LblVignetteTitle" Text="EDGE FADE"
                                                   Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <CheckBox x:Name="ToggleVignette"
                                                  Style="{StaticResource SmallToggleSwitchStyle}"
                                                  IsChecked="False" IsEnabled="False"
                                                  Checked="ToggleVignette_Changed" Unchecked="ToggleVignette_Changed"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblCurvatureAmount" Text="AMOUNT"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderCurvature" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="0" IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderCurvature_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtCurvaturePct"
                                               Text="{Binding Value, ElementName=SliderCurvature, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- ── BLUR ── -->
                                <Grid Margin="0,16,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleBlur" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="False"
                                              Checked="ToggleBlur_Changed" Unchecked="ToggleBlur_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblBlurTitle" Text="BLUR"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblBlurIntensity" Text="INTENSITY"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderBlur" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="0" IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtBlurPct"
                                               Text="{Binding Value, ElementName=SliderBlur, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- ── BLOOM ── -->
                                <Grid Margin="0,16,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleBloom" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="False"
                                              Checked="ToggleBloom_Changed" Unchecked="ToggleBloom_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblBloomTitle" Text="BLOOM"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblBloomIntensity" Text="INTENSITY"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderBloom" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="0" IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderBloom_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtBloomPct"
                                               Text="{Binding Value, ElementName=SliderBloom, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- ── FLICKER ── -->
                                <Grid Margin="0,16,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleFlicker" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="False"
                                              Checked="ToggleFlicker_Changed" Unchecked="ToggleFlicker_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblFlickerTitle" Text="FLICKER"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblFlickerIntensity" Text="INTENSITY"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderFlicker" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="0"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderFlicker_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtFlickerPct"
                                               Text="{Binding Value, ElementName=SliderFlicker, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,8,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblFlickerRate" Text="RATE"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderFlickerRate" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="25"
                                            IsEnabled="False"
                                            Tag="25" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderFlickerRate_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtFlickerRatePct"
                                               Text="{Binding Value, ElementName=SliderFlickerRate, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- ── PHOSPHOR GLOW ── -->
                                <Grid Margin="0,16,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="TogglePhosphor" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="False"
                                              Checked="TogglePhosphor_Changed" Unchecked="TogglePhosphor_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblPhosphorTitle" Text="PHOSPHOR GLOW"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblPhosphorIntensity" Text="INTENSITY"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderPhosphor" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="0"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderPhosphor_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtPhosphorPct"
                                               Text="{Binding Value, ElementName=SliderPhosphor, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- ── LUMINOSITY COMPENSATION ── -->
                                <Grid Margin="0,16,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleLuma" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="False"
                                              Checked="ToggleLuma_Changed" Unchecked="ToggleLuma_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblLumaTitle" Text="LUMINOSITY COMPENSATION"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <!-- Brightness slider -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblBrightnessLbl" Text="BRIGHTNESS"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderBrightness" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="-100" Maximum="100" Value="0"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderBrightness_ValueChanged"
                                            Loaded="CenterSlider_Loaded"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtBrightnessPct"
                                               Text="{Binding Value, ElementName=SliderBrightness, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                <!-- Contrast slider -->
                                <Grid Margin="0,10,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblContrastLbl" Text="CONTRAST"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderContrast" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="-100" Maximum="100" Value="0"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderContrast_ValueChanged"
                                            Loaded="CenterSlider_Loaded"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtContrastPct"
                                               Text="{Binding Value, ElementName=SliderContrast, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                <!-- Saturation slider -->
                                <Grid Margin="0,10,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblSaturationLbl" Text="SATURATION"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderSaturation" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="-100" Maximum="100" Value="0"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderSaturation_ValueChanged"
                                            Loaded="CenterSlider_Loaded"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtSaturationPct"
                                               Text="{Binding Value, ElementName=SliderSaturation, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                <!-- Temperature slider -->
                                <Grid Margin="0,10,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblTemperatureLbl" Text="TEMPERATURE"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderTemperature" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="-100" Maximum="100" Value="0"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderTemperature_ValueChanged"
                                            Loaded="CenterSlider_Loaded"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtTemperaturePct"
                                               Text="{Binding Value, ElementName=SliderTemperature, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                <!-- Black Level slider -->
                                <Grid Margin="0,10,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblBlackLevelLbl" Text="BLACK LEVEL"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderBlackLevel" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="0"
                                            SmallChange="1" LargeChange="5"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderBlackLevel_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtBlackLevelVal"
                                               Text="{Binding Value, ElementName=SliderBlackLevel, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                                <!-- Gamma slider -->
                                <Grid Margin="0,10,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblGammaLbl" Text="GAMMA"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderGamma" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="50" Maximum="200" Value="100"
                                            SmallChange="1" LargeChange="5"
                                            IsEnabled="False"
                                            Tag="100" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderGamma_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtGammaVal"
                                               Text="{Binding Value, ElementName=SliderGamma, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                </StackPanel><!-- /CrtGroupContentPanel -->
                            </StackPanel><!-- /CrtGroupBody -->
                        </StackPanel>
                    </Border>

                    <!-- ═══════ VHS + FILM GRAIN ═══════ -->
                    <Border Background="#0D1017" CornerRadius="10" Padding="18,18"
                            Margin="0,0,0,12" BorderBrush="#1A1D28" BorderThickness="1">
                        <StackPanel>
                            <!-- Header with toggle -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="ToggleVhs" Grid.Column="0"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          IsChecked="False"
                                          Checked="ToggleVhs_Changed" Unchecked="ToggleVhs_Changed"/>
                                <TextBlock Grid.Column="1" x:Name="LblVhsTitle" Text="VHS"
                                           Foreground="#555555" FontSize="13" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <Border x:Name="InfoVhs" Grid.Column="2" Width="15" Height="15" CornerRadius="8"
                                        BorderThickness="1" Background="Transparent"
                                        Margin="6,0,4,0" VerticalAlignment="Center" Cursor="Hand"
                                        IsEnabled="True"
                                        ToolTipService.InitialShowDelay="0"
                                        ToolTipService.ShowOnDisabled="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#4B5563"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FF2AFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="i" FontSize="9" FontWeight="Bold"
                                               FontFamily="Segoe UI" FontStyle="Italic"
                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#6B7280"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF2AFF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <Button x:Name="BtnCollapseVhs" Grid.Column="4"
                                        Style="{StaticResource CrtCollapseBtn}"
                                        Click="BtnCollapseVhs_Click"
                                        VerticalAlignment="Center" Content="▲"/>
                            </Grid>

                            <StackPanel x:Name="VhsBody" Visibility="Visible">
                                <!-- VHS Effect sub-toggle -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleVhsEffect" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="True"
                                              Checked="ToggleVhsEffect_Changed" Unchecked="ToggleVhsEffect_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblVhsEffectTitle" Text="VHS EFFECT"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <!-- VHS Intensity slider -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblVhsIntensity" Text="INTENSITY"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderVhs" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="50"
                                            SmallChange="1" LargeChange="5"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderVhs_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtVhsPct"
                                               Text="{Binding Value, ElementName=SliderVhs, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- Film Grain sub-toggle -->
                                <Grid Margin="0,16,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleGrain" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="False"
                                              Checked="ToggleGrain_Changed" Unchecked="ToggleGrain_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblGrainTitle" Text="FILM GRAIN"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>

                                <!-- Grain Intensity slider -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblGrainIntensity" Text="INTENSITY"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderGrain" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="30"
                                            SmallChange="1" LargeChange="5"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderGrain_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtGrainPct"
                                               Text="{Binding Value, ElementName=SliderGrain, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- Tape Noise sub-toggle -->
                                <Grid Margin="0,8,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="ToggleTapeNoise" Grid.Column="0"
                                              Style="{StaticResource SmallToggleSwitchStyle}"
                                              IsChecked="False"
                                              Checked="ToggleTapeNoise_Changed" Unchecked="ToggleTapeNoise_Changed"/>
                                    <TextBlock Grid.Column="1" x:Name="LblTapeNoiseTitle" Text="TAPE NOISE"
                                               Foreground="#555555" FontSize="10" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="SliderLabel"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="LblTapeNoiseIntensity" Text="INTENSITY"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Slider x:Name="SliderTapeNoise" Grid.Column="1"
                                            Style="{StaticResource GraySlider}"
                                            Minimum="0" Maximum="100" Value="50"
                                            SmallChange="1" LargeChange="5"
                                            IsEnabled="False"
                                            Tag="0" PreviewMouseLeftButtonDown="Slider_ResetOnDoubleClick"
                                            AutoToolTipPlacement="TopLeft"
                                            ValueChanged="SliderTapeNoise_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="TxtTapeNoisePct"
                                               Text="{Binding Value, ElementName=SliderTapeNoise, StringFormat={}{0:0}%}"
                                               Foreground="#555555" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                            </StackPanel>
                        </StackPanel>
                    </Border>

                    </StackPanel><!-- /CrtEffectsBody -->

                </StackPanel>
            </ScrollViewer>

                        <!-- ═══════ FOOTER ═══════ -->
            <Border Grid.Row="3" Background="#080A10" Padding="18,10,18,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <!-- SAVE : sombre au repos, flash rose au clic -->
                    <Button x:Name="BtnSaveBtn" Click="BtnSave_Click"
                            Cursor="Hand" Margin="0,0,12,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1E2230"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#2A2D38"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="Padding" Value="20,0"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2A2D38"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF2AFF"/>
                                                    <Setter Property="Foreground" Value="#1A0A1A"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="flash">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF2AFF"/>
                                                    <Setter Property="Foreground" Value="#1A0A1A"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtBtnSave" Text="Save"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- APPLY : sombre au repos, rose enfoncé quand overlay actif -->
                    <Button x:Name="BtnApplyBtn" Click="BtnApply_Click"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1E2230"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#2A2D38"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="Padding" Value="20,0"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2A2D38"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF2AFF"/>
                                                    <Setter Property="Foreground" Value="#1A0A1A"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="active">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FF2AFF"/>
                                                    <Setter Property="Foreground" Value="#1A0A1A"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FF2AFF"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtBtnApply" Text="Apply"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>

            <!-- ═══════ STATUS BAR ═══════ -->
            <Border Grid.Row="4" Background="#080A10" CornerRadius="0,0,12,12"
                    Padding="16,7,16,7">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="#22C55E" Margin="0,0,6,0"/>
                        <TextBlock x:Name="LblStatus" Text="READY" Foreground="#22C55E"
                                   FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <!-- Update available button — hidden until update detected -->
                        <Button x:Name="BtnUpdateAvailable" Visibility="Collapsed"
                                Cursor="Hand" Margin="0,0,10,0"
                                Click="BtnUpdateAvailable_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock x:Name="LblUpdateAvailable" Text="● UPDATE AVAILABLE"
                                       Foreground="#FF2AFF" FontSize="11" FontFamily="Segoe UI"
                                       FontWeight="SemiBold"/>
                        </Button>
                        <TextBlock x:Name="LblAppVersion" Text="v1.2"
                                   Foreground="#6B7280" FontSize="11" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
