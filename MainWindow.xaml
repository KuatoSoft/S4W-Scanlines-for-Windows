<Border Background="#151921" CornerRadius="10" BorderBrush="#1A1D28" BorderThickness="1" Padding="16,14" Margin="0,0,0,8">
    <!-- Associated Profile -->
    <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock x:Name="LblAssociatedProfile" Text="ASSOCIATED PROFILE" Foreground="#6B7280" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
        </StackPanel>
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" x:Name="CmbProfile" Style="{StaticResource DarkComboBox}" IsEditable="True" MaxDropDownHeight="450" SelectionChanged="CmbProfile_SelectionChanged">
                <ComboBoxItem Content="Desktop" IsSelected="True"/>
            </ComboBox>
            <!-- Prev profile -->
            <Button Grid.Column="1" x:Name="BtnProfilePrev" Content="◀"
                    Width="28" Height="34" Padding="0"
                    Click="BtnProfilePrev_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#1E2230"/>
                        <Setter Property="Foreground" Value="#6B7280"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="#2A2D38" BorderThickness="1"
                                            CornerRadius="6,0,0,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2D38"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <!-- Next profile -->
            <Button Grid.Column="2" x:Name="BtnProfileNext" Content="▶"
                    Width="28" Height="34" Padding="0" Margin="0,0,8,0"
                    Click="BtnProfileNext_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#1E2230"/>
                        <Setter Property="Foreground" Value="#6B7280"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="#2A2D38" BorderThickness="1"
                                            CornerRadius="0,6,6,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2D38"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Button Grid.Column="3" x:Name="BtnResetProfileBtn" Content="Reset" Style="{StaticResource DarkButton}" Click="BtnResetProfile_Click" Margin="0,0,8,0"/>
            <Button Grid.Column="4" x:Name="BtnDeleteProfileBtn" Style="{StaticResource DarkButton}"
                    Click="BtnDeleteProfile_Click" Padding="10,6"/>
        </Grid>
        
        <!-- Application/Emulator Path (hidden for Desktop profile) -->
        <StackPanel x:Name="AppPathSection">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="LblAppPath" Text="APPLICATION/EMULATOR PATH" Foreground="#6B7280" FontSize="10" FontWeight="SemiBold" FontFamily="Segoe UI"/>
            </StackPanel>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="CmbAppPath" Style="{StaticResource DarkComboBox}" Margin="0,0,6,0"/>
                <Button Grid.Column="1" x:Name="BtnAppSearchBtn" Content="Set Path" Style="{StaticResource DarkButton}" Click="BtnAppSearch_Click" Margin="0,0,4,0"/>
                <Button Grid.Column="2" x:Name="BtnPickProcessBtn" Content="Set Process" Style="{StaticResource DarkButton}" Click="BtnPickProcess_Click" Margin="0,0,4,0"/>
                <Button Grid.Column="3" x:Name="BtnAppDeleteBtn" Style="{StaticResource DarkButton}"
                        Click="BtnAppDelete_Click" Padding="10,6"/>
            </Grid>
        </StackPanel>
        <!-- Running processes picker (hidden by default) -->
        <Border x:Name="ProcessPickerPanel" Visibility="Collapsed"
                Background="#0D1117" CornerRadius="6" BorderBrush="#2A2D38" BorderThickness="1"
                Padding="0" MaxHeight="220">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <!-- Header -->
                <Grid Grid.Row="0" Margin="8,6,8,4">
                    <TextBlock Text="RUNNING PROCESSES" Foreground="#6B7280" FontSize="9" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>
                <!-- Process list -->
                <ListBox Grid.Row="1" x:Name="LstRunningProcesses"
                         Background="Transparent" BorderThickness="0"
                         Foreground="White" FontSize="13" FontFamily="Segoe UI"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionChanged="LstRunningProcesses_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <EventSetter Event="PreviewMouseLeftButtonDown"
                                         Handler="LstProcessItem_PreviewMouseDown"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A1D28"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2A1A2E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                <!-- Footer with Add button -->
                <Border Grid.Row="2" Background="#0A0C12" BorderBrush="#1A1D28" BorderThickness="0,1,0,0"
                        CornerRadius="0,0,6,6" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LblPickedProcess" Text="Select a process above"
                                   Foreground="#4B5563" FontSize="10" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Content="&#xE149;" FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource DarkButton}" FontSize="12" Padding="10,0" Height="22"
                                Margin="0,0,4,0"
                                Click="BtnRefreshProcesses_Click" ToolTip="Refresh list"/>
                        <Button Grid.Column="2" x:Name="BtnAddProcess" Content="Add"
                                Style="{StaticResource DarkButton}" Height="22" Padding="10,0"
                                IsEnabled="False" Click="BtnAddProcess_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <!-- Borderless Windowed Fullscreen toggle -->
        <Grid x:Name="BorderlessRow" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="&#xE740;" FontFamily="Segoe MDL2 Assets"
                       FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="LblBorderlessToggle"
                           Text="Borderless Windowed Fullscreen"
                           Foreground="White" FontSize="11" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <!-- Info icon -->
                <Border x:Name="InfoBorderless" Width="15" Height="15" CornerRadius="8"
                        BorderThickness="1"
                        Background="Transparent"
                        Margin="6,0,0,0" VerticalAlignment="Center" Cursor="Hand"
                        IsEnabled="True"
                        ToolTipService.InitialShowDelay="0"
                        ToolTipService.ShowOnDisabled="True">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#4B5563"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#FF2AFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="i" FontSize="9" FontWeight="Bold"
                               FontFamily="Segoe UI" FontStyle="Italic"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                        <Setter Property="Foreground" Value="#FF2AFF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </StackPanel>
            <ToggleButton Grid.Column="2" x:Name="ToggleBorderless"
                          Style="{StaticResource ToggleSwitchStyle}"
                          IsChecked="False"
                          Checked="ToggleBorderless_Changed"
                          Unchecked="ToggleBorderless_Changed"/>
        </Grid>
    </StackPanel>
</Border>

